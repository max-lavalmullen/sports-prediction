# Sports Prediction Platform Configuration
# Copy this file to .env (in project root) and fill in your values

# ============================================================
# REQUIRED: Get your free API key
# ============================================================

# The Odds API - Real-time odds from 10+ sportsbooks
# Get your FREE key at: https://the-odds-api.com
# (500 requests/month free - plenty for personal use)
ODDS_API_KEY=your_key_here

# ============================================================
# DATABASE (auto-configured for Docker)
# ============================================================
POSTGRES_USER=sports
POSTGRES_PASSWORD=sports_password
POSTGRES_DB=sports_prediction
DATABASE_URL=postgresql://sports:sports_password@localhost:5432/sports_prediction

# ============================================================
# REDIS (auto-configured for Docker)
# ============================================================
REDIS_URL=redis://localhost:6379

# ============================================================
# APPLICATION SETTINGS
# ============================================================
APP_NAME="Sports Prediction Platform"
ENVIRONMENT=development
DEBUG=true

# Security (generate a new key for production!)
# Run: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ============================================================
# ML SETTINGS
# ============================================================
MODEL_PATH=./ml/saved_models
PREDICTION_CACHE_TTL=300

# ============================================================
# BETTING SETTINGS
# ============================================================
BANKROLL_DEFAULT=10000
KELLY_FRACTION_DEFAULT=0.25
MIN_EDGE_THRESHOLD=0.03

# ============================================================
# FRONTEND (for Vite/React)
# ============================================================
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000

# ============================================================
# OPTIONAL: Additional APIs (not required for core functionality)
# ============================================================

# Sportradar (premium sports data - not needed)
# SPORTRADAR_API_KEY=

# Twitter/X (for injury news - not needed)
# TWITTER_BEARER_TOKEN=
# TWITTER_API_KEY=
# TWITTER_API_SECRET=

# Betfair (for future bot integration - not needed)
# BETFAIR_APP_KEY=
# BETFAIR_USERNAME=
# BETFAIR_PASSWORD=
